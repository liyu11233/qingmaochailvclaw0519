# 本文件只作为示例。
# 需要本机自定义时，复制为 .env 后再修改：
# cp .env.example .env

# 本地管理端端口
PORT=5173

# 三平台入口。URL 里带 # 时建议保留引号，方便 macOS 启动脚本 source .env。
QINGMAO_TRAVEL_URL="https://booking.tmctrip.com/TravelBooking"
CTRIP_BUSINESS_URL="https://ct.ctrip.com/login"
ALIBABA_BUSINESS_URL="https://travel.alibtrip.com/index.html#/login"

# Playwright 优先使用的本机浏览器路径。
# 默认代码也会依次尝试 Google Chrome、Microsoft Edge、Chromium。
PLAYWRIGHT_CHROMIUM_EXECUTABLE="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
